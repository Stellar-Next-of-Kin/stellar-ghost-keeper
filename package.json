{
  "name": "stellar-ghost-keeper",
  "version": "1.0.0",
  "description": "Off-chain automation service for StellarGhost inheritance triggers",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "dry-run": "tsx src/index.ts --dry-run",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest"
  },
  "dependencies": {
    "@stellar/js-stellar-sdk": "^12.0.0",
    "dotenv": "^16.3.0",
    "axios": "^1.6.0",
    "winston": "^3.11.0",
    "ioredis": "^5.3.0"
  },
  "devDependencies": {
    "typescript": "^5.2.0",
    "@types/node": "^20.8.0",
    "tsx": "^3.14.0",
    "eslint": "^8.50.0",
    "prettier": "^3.0.0",
    "vitest": "^0.34.0"
  }
}
